(ns jank-stb-image-test.main)

(cpp/raw "#include <emutls.hpp>")
(cpp/raw "#define STB_IMAGE_IMPLEMENTATION")
(cpp/raw "#include <stb_image.h>")

(defn -main [& args]
  (let [width (cpp/int)
          height (cpp/int)
          channel-count (cpp/int)
          image (cpp/stbi_load "horse-0.png" (cpp/& width) (cpp/& height) (cpp/& channel-count) 0)]
      
      (when (cpp/== cpp/nullptr image)
        (throw (ex-info "Error: Could not load image\n" {})))
      
      (println (str "Image loaded: " width "x" height ", channels: " channel-count))
      (cpp/stbi_image_free image)))